{
  "type": "object",
  "additionalProperties": false,

  "required": [
    "event_id",
    "event_created_at",
    "event_timestamp",
    "pipeline_source",
    "ingestion_mode",
    "transaction_id",
    "step",
    "transaction_type",
    "amount",
    "customer_id",
    "merchant_id",
    "old_balance_orig",
    "new_balance_orig",
    "old_balance_dest",
    "new_balance_dest",
    "is_fraud",
    "synthetic_anomaly",
    "is_synthetic_anomaly",
    "transaction_velocity"
  ],

  "properties": {

    "event_id": {
      "type": "string",
      "minLength": 1,
      "description": "UUID for this event envelope (not the transaction itself)"
    },

    "event_created_at": {
      "type": "string",
      "minLength": 1,
      "description": "ISO-8601 wall-clock time the event object was constructed"
    },

    "event_timestamp": {
      "type": "string",
      "minLength": 1,
      "description": "ISO-8601 logical event time derived from PaySim step"
    },

    "pipeline_source": {
      "type": "string",
      "minLength": 1,
      "description": "Origin dataset identifier"
    },

    "ingestion_mode": {
      "type": "string",
      "enum": ["streaming", "batch"],
      "description": "How this event entered the pipeline"
    },

    "transaction_id": {
      "type": "string",
      "minLength": 1,
      "description": "UUID that uniquely identifies this transaction"
    },

    "step": {
      "type": "integer",
      "minimum": 0,
      "description": "PaySim simulation step (maps to hours elapsed)"
    },

    "transaction_type": {
      "type": "string",
      "enum": ["CASH_IN", "CASH_OUT", "DEBIT", "PAYMENT", "TRANSFER"],
      "description": "PaySim transaction category"
    },

    "amount": {
      "type": "number",
      "minimum": 0,
      "description": "Transaction value in simulation currency units"
    },

    "customer_id": {
      "type": "string",
      "minLength": 1,
      "description": "Originating account identifier (nameOrig)"
    },

    "merchant_id": {
      "type": "string",
      "minLength": 1,
      "description": "Destination account / merchant identifier (nameDest)"
    },

    "old_balance_orig": {
      "type": "number",
      "minimum": 0,
      "description": "Originator balance before transaction"
    },

    "new_balance_orig": {
      "type": "number",
      "minimum": 0,
      "description": "Originator balance after transaction"
    },

    "old_balance_dest": {
      "type": "number",
      "minimum": 0,
      "description": "Destination balance before transaction"
    },

    "new_balance_dest": {
      "type": "number",
      "minimum": 0,
      "description": "Destination balance after transaction"
    },

    "is_fraud": {
      "type": "integer",
      "enum": [0, 1],
      "description": "PaySim ground-truth fraud label"
    },

    "synthetic_anomaly": {
      "type": ["string", "null"],
      "enum": ["high_amount", "rapid_repeat", "merchant_spike", null],
      "description": "Type of injected anomaly, or null if none"
    },

    "is_synthetic_anomaly": {
      "type": "integer",
      "enum": [0, 1],
      "description": "1 if a synthetic anomaly was injected, 0 otherwise"
    },

    "transaction_velocity": {
      "type": "integer",
      "minimum": 1,
      "description": "Estimated number of transactions by this customer in the current window"
    }
  }
}